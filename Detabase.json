<div id="data-display" style="background: #161b22; padding: 15px; border: 1px solid #00ffcc; border-radius: 10px; color: #fff;">
    ටිකක් ඉන්න, දත්ත Load වෙනවා...
</div>

<script>
    fetch('https://raw.githubusercontent.com/KING-JANA-MODZ/C.E.B-PROJECT/main/db.txt')
    .then(response => response.text())
    .then(data => {
        document.getElementById('data-display').innerHTML = data || "දැනට දත්ත ඇතුළත් කර නොමැත.";
    })
    .catch(err => {
        document.getElementById('data-display').innerHTML = "කෝඩ් එකේ මොකක් හරි අවුලක් තියෙනවා.";
    });
</script>
