<div id="display-area" style="color: #00ffcc; font-family: monospace;">
    Loading...
</div>

<script>
    async function loadData() {
        try {
            const url = "https://raw.githubusercontent.com/KING-JANA-MODZ/C.E.B-PROJECT/refs/heads/main/Detabase.json";
            const res = await fetch(url);
            const data = await res.json();
            
            const area = document.getElementById('display-area');
            if(data.length === 0) {
                area.innerHTML = "දැනට සැලසුම්ගත කප්පාදුවක් නොමැත.";
            } else {
                area.innerHTML = data.map(x => `
                    <div style="background: #161b22; padding: 10px; margin: 10px 0; border-radius: 5px; border-left: 4px solid #00ffcc;">
                        <strong>📅 ${x.d}</strong> | ${x.t}<br>
                        <strong>📍 ${x.a}</strong>
                    </div>`).join('');
            }
        } catch (e) {
            document.getElementById('display-area').innerHTML = "දත්ත ලබාගත නොහැක.";
        }
    }
    loadData();
</script>
